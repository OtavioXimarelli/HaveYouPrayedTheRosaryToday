# Feature Flags

# Enable/disable the cursor glow effect that follows the mouse
# Set to 'false' to disable, leave unset or 'true' to enable (default: true)
NEXT_PUBLIC_CURSOR_GLOW_ENABLED=true

# Enable/disable Magic Bento hover effects on cards
# Set to 'false' to disable, leave unset or 'true' to enable (default: true)
NEXT_PUBLIC_MAGIC_BENTO_ENABLED=true

# Enable/disable theme persistence across sessions
# Set to 'false' to disable, leave unset or 'true' to enable (default: true)
NEXT_PUBLIC_THEME_PERSISTENCE_ENABLED=true
